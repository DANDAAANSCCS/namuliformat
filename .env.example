# ═══════════════════════════════════════════
# NamuLiFormat - Configuración
# ═══════════════════════════════════════════

# Railway genera esto automáticamente al agregar PostgreSQL
DATABASE_URL=postgresql://user:password@host:port/database

# Puerto (Railway lo asigna automáticamente)
PORT=3000

# URL base de tu app (cambiar por tu dominio de Railway)
BASE_URL=https://tu-app.up.railway.app

# Contraseña del panel admin (cámbiala!)
ADMIN_PASSWORD=admin123

# Contraseña por defecto del primer empleado
EMPLOYEE_PASSWORD=empleado123

# Tu número de WhatsApp
ADMIN_WHATSAPP=+528121968034

# Teléfono del empleado (opcional)
EMPLOYEE_WHATSAPP=

# Entorno
NODE_ENV=production
